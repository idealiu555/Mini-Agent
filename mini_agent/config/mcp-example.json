{
    "mcpServers": {
        "tavily_search": {
            "description": "Tavily Search - Real-time web search, extract, map, and crawl",
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "tavily-mcp@latest"
            ],
            "env": {
                "TAVILY_API_KEY": ""
            },
            "disabled": true
        },
        "memory": {
            "description": "Memory - Knowledge graph memory system (long-term memory based on graph database)",
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-memory"
            ],
            "disabled": true
        }
    }
}